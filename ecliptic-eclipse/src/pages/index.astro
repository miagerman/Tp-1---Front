---
const comidas = [
  { nombre: "Pizza", categoria: "Rapida", emoji: "🍕" },
  { nombre: "Hamburguesa", categoria: "Rapida", emoji: "🍔" },
  { nombre: "Empanadas", categoria: "Tradicional", emoji: "🥟" },
  { nombre: "Asado", categoria: "Tradicional", emoji: "🥩" },
  { nombre: "Ensalada", categoria: "Saludable", emoji: "🥗" },
  { nombre: "Sushi", categoria: "Saludable", emoji: "🍣" },
  { nombre: "Helado", categoria: "Postre", emoji: "🍨" },
  { nombre: "Torta", categoria: "Postre", emoji: "🍰" }
];
---

<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Comidas</title>

  <style>
    body { font-family: Arial; }

    header {
      background: orange;
      color: white;
      text-align: center;
      padding: 20px;
    }

    nav a {
      color: white;
      margin: 5px;
      text-decoration: none;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
      padding: 10px;
    }

    .card {
      border: 1px solid black;
      padding: 10px;
      text-align: center;
    }

    @media (max-width: 800px) {
      .grid { grid-template-columns: 2fr 2fr; }
    }

    @media (max-width: 500px) {
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</head>

<body>

<header>
  <h1>Catálogo de Comidas</h1>
  <nav>
    <a href="#catalogo">Catálogo</a>
    <a href="#sobre">Sobre</a>
    <a href="#contacto">Contacto</a>
  </nav>
</header>

<section id="catalogo">
  <h2>Catálogo</h2>

  <input id="buscador" placeholder="buscar">
  
  <select id="filtro">
    <option value="Todas">Todas</option>
    <option value="Rapida">Rapida</option>
    <option value="Tradicional">Tradicional</option>
    <option value="Saludable">Saludable</option>
    <option value="Postre">Postre</option>
  </select>

  <div class="grid">
    {comidas.map(c => (
      <div class="card" data-nombre={c.nombre.toLowerCase()} data-cat={c.categoria}>
        <div>{c.emoji}</div>
        <p>{c.nombre}</p>
      </div>
    ))}
  </div>
</section>

<section id="Sobre el Proyecto">
  <h2>Sobre el Proyecto</h2>
  <p>Hola a todos. Este es mi catálogo de comidas con algunas de mis comidas favoritas.
    La idea es poder explorarlas, buscarlas y filtrarlas por categoría.
    Espero que les guste y que tengan un paladar parecido al mío.
</p>
</section>

<section id="contacto">
  <h2>Contacto</h2>
  <p>  
    Hola, soy Mia German. Si querés contactarte conmigo, mi Gmail es: miagerman20082020@gmail.com
  </p>
  <button id="btn">Click</button>
  <p id="msg"></p>
</section>

<script is:inline>
const b = document.getElementById("buscador");
const f = document.getElementById("filtro");
const cards = document.querySelectorAll(".card");
const no = document.getElementById("no");

function filtrar() {
  let t = b.value.toLowerCase();
  let cat = f.value;
  let count = 0;

  cards.forEach(c => {
    let n = c.getAttribute("data-nombre");
    let c2 = c.getAttribute("data-cat");

    if (n.includes(t) && (cat=="Todas" || c2==cat)) {
      c.style.display="block";
      count++;
    } else {
      c.style.display="none";
    }
  });

  no.style.display = count==0 ? "block" : "none";
}

b.addEventListener("input", filtrar);
f.addEventListener("change", filtrar);

document.getElementById("btn").onclick = () => {
  document.getElementById("msg").innerText = "Gracias por visitar";
};
</script>

</body>
</html>